{
  "info": {
    "_postman_id": "a1b2c3d4-contact-mgmt",
    "name": "Contact Management System",
    "description": "Full API collection for the Advanced Contact Management System (Spring Boot + JWT + MongoDB).\n\n**Setup:**\n1. Run the backend on port 8080.\n2. Run **Auth → Login** (or Register).\n3. Copy `token` from the response into the collection variable `token`, or use a Postman test script to set it.\n4. Contact requests use **Authorization: Bearer {{token}}**.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "contactId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register",
            "description": "Creates a user in `users` collection. Returns JWT."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret12\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Returns JWT. Test script saves token to collection variable `token`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/dashboard/stats",
            "description": "Total contacts and 5 most recent for the authenticated user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Contacts",
      "item": [
        {
          "name": "Add Contact",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.id) {",
                  "  pm.collectionVariables.set('contactId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"+1-555-0100\",\n  \"address\": \"123 Main St\"\n}"
            },
            "url": "{{baseUrl}}/api/contacts",
            "description": "Creates a contact for the logged-in user. Saves `contactId` from response."
          },
          "response": []
        },
        {
          "name": "Get All Contacts (Paginated)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/contacts?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "GET /api/contacts?page=0&size=10"
          },
          "response": []
        },
        {
          "name": "Get Contact By ID",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/contacts/{{contactId}}",
            "description": "GET /api/contacts/{id}. Set `contactId` or run Add Contact first."
          },
          "response": []
        },
        {
          "name": "Update Contact",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane.updated@example.com\",\n  \"phone\": \"+1-555-0199\",\n  \"address\": \"456 Oak Ave\"\n}"
            },
            "url": "{{baseUrl}}/api/contacts/{{contactId}}",
            "description": "PUT /api/contacts/{id}"
          },
          "response": []
        },
        {
          "name": "Search Contacts",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/contacts/search?query=jane&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contacts", "search"],
              "query": [
                { "key": "query", "value": "jane" },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            },
            "description": "GET /api/contacts/search?query= — matches name or email (case-insensitive)."
          },
          "response": []
        },
        {
          "name": "Delete Contact",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/contacts/{{contactId}}",
            "description": "DELETE /api/contacts/{id} — 204 No Content on success."
          },
          "response": []
        }
      ]
    }
  ]
}
